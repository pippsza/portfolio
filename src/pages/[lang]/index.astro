---
import Layout from '../../layouts/Layout.astro';
import { dictionary, projects, skills, socials, type Locale } from '../../constants/data';
import Button from '../../components/ui/Button';
import Card from '../../components/ui/Card';
import Badge from '../../components/ui/Badge';
import Icon from '../../components/Icon';
import DevOpsPipeline from '../../components/DevOpsPipeline';
import { Image } from 'astro:assets';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'uk' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang } = Astro.params as { lang: Locale };
const t = dictionary[lang];
const localizedProjects = projects[lang];
---

<Layout title={`${t.greeting} | Portfolio`} description={t.heroDescription} lang={lang}>
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center px-6">
    <div class="container mx-auto text-center">
      <div class="space-y-6 animate-fade-in">
        <h1 class="text-5xl md:text-7xl font-bold">
          <span class="block mb-2">{t.greeting}</span>
          <span class="bg-gradient-to-r from-primary via-secondary to-accent bg-clip-text text-transparent">
            Astakhov Bohdan
          </span>
        </h1>
        
        <p class="text-2xl md:text-3xl font-semibold text-gray-300">
          {t.role}
        </p>
        
        <p class="text-lg md:text-xl text-gray-400 max-w-3xl mx-auto">
          {t.heroDescription}
        </p>
        
        <div class="flex flex-wrap gap-4 justify-center mt-8">
          <Button variant="primary" size="lg" href={`/${lang}/#contact`}>
            {t.contactMe}
          </Button>
          <Button variant="outline" size="lg" href={`/${lang}/#projects`}>
            {t.viewProjects}
          </Button>
        </div>
        
        <!-- Social Links -->
        <div class="flex gap-6 justify-center mt-12">
          {socials.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="p-3 rounded-full border border-gray-700 hover:border-primary hover:scale-110 transition-all duration-200"
              aria-label={social.name}
              title={social.name}
            >
              <Icon name={social.iconName} size={24} client:load />
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-24 px-6">
    <div class="container mx-auto max-w-4xl">
      <h2 class="text-4xl md:text-5xl font-bold text-center mb-6">
        {t.aboutTitle}
      </h2>
      <p class="text-xl text-gray-400 text-center max-w-3xl mx-auto">
        {t.aboutDescription}
      </p>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-24 px-6 bg-gray-900/30">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">
          {t.projectsTitle}
        </h2>
        <p class="text-xl text-gray-400">
          {t.projectsDescription}
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        {localizedProjects.map((project) => (
          <Card client:load>
            <div class="space-y-4">
              <!-- Project Image Placeholder -->
              <div class="w-full h-48 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-lg flex items-center justify-center">
                <Icon name="Layers" size={64} class="text-primary/50" client:load />
              </div>
              
              <h3 class="text-2xl font-bold">{project.title}</h3>
              <p class="text-gray-400">{project.description}</p>
              
              <div class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <Badge client:load>{tag}</Badge>
                ))}
              </div>
              
              <div class="flex gap-4 pt-4">
                {project.link && (
                  <Button variant="primary" size="sm" href={project.link} client:load>
                    <Icon name="ExternalLink" size={16} class="mr-2" client:load />
                    {t.viewProject}
                  </Button>
                )}
                {project.github && (
                  <Button variant="outline" size="sm" href={project.github} client:load>
                    <Icon name="Github" size={16} class="mr-2" client:load />
                    {t.viewCode}
                  </Button>
                )}
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="py-24 px-6">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">
          {t.skillsTitle}
        </h2>
        <p class="text-xl text-gray-400">
          {t.skillsDescription}
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        {Object.entries(skills).map(([category, skillList]) => (
          <Card client:load hover={false}>
            <h3 class="text-2xl font-bold mb-6 text-center text-primary">
              {category}
            </h3>
            <div class="space-y-4">
              {skillList.map((skill) => (
                <div class="flex items-center gap-3 p-3 rounded-lg bg-gray-800/50 hover:bg-gray-800 transition-colors">
                  <Icon name={skill.iconName} size={24} class="text-primary" client:load />
                  <span class="font-medium">{skill.name}</span>
                </div>
              ))}
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- DevOps Pipeline Section -->
  <section class="py-24 px-6 bg-gray-900/30">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">
          {t.devOpsTitle}
        </h2>
        <p class="text-xl text-gray-400">
          {t.devOpsDescription}
        </p>
      </div>
      
      <DevOpsPipeline client:load />
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-24 px-6">
    <div class="container mx-auto max-w-2xl text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        {t.contactTitle}
      </h2>
      <p class="text-xl text-gray-400 mb-8">
        {t.contactDescription}
      </p>
      
      <div class="flex flex-wrap gap-6 justify-center">
        {socials.map((social) => (
          <Button 
            variant="primary" 
            size="lg" 
            href={social.url}
            client:load
          >
            <Icon name={social.iconName} size={20} class="mr-2" client:load />
            {social.name}
          </Button>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in {
    animation: fade-in 1s ease-out;
  }
</style>
