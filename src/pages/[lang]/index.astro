---
import Layout from '../../layouts/Layout.astro';
import { dictionary, projects, skills, socials, experience, type Locale } from '../../constants/data';
import Icon from '../../components/Icon';
import DevOpsPipeline from '../../components/DevOpsPipeline';
import SkillsCarousel from '../../components/SkillsCarousel';
import ProjectCard from '../../components/ProjectCard';
import ExperienceCard from '../../components/ExperienceCard';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'uk' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang } = Astro.params as { lang: Locale };
const t = dictionary[lang];
const localizedProjects = projects[lang];
const localizedExperience = experience[lang];
---

<Layout title={`Astakhov Bohdan | pippsza - Full Stack Developer`} description={`${t.heroDescription} | Portfolio of Astakhov Bohdan (@pippsza)`} lang={lang}>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center px-6 py-4 md:py-12">
    <div class="container mx-auto relative z-10">
      <div class="flex flex-col lg:flex-row items-center justify-center gap-12 lg:gap-20">

        <!-- Photo Circle -->
        <div class="relative animate-fade-in-up order-1 lg:order-2" style="animation-delay: 0.2s;">
          <div class="photo-circle">
            <div class="w-full h-full bg-gradient-to-br from-surface to-primary flex items-center justify-center">
              <Icon name="Code2" size={80} class="text-accent opacity-50" client:load />
            </div>
          </div>
          <!-- Decorative rings -->
          <div class="absolute -inset-4 border border-accent/20 rounded-full animate-pulse-glow" style="animation-duration: 3s;" />
          <div class="absolute -inset-8 border border-accent/10 rounded-full" />
        </div>

        <!-- Text Content -->
        <div class="text-center lg:text-left space-y-6 order-2 lg:order-1 max-w-2xl">
          <div class="animate-fade-in-up" style="animation-delay: 0s;">
            <p class="text-accent font-medium text-lg mb-2">{t.greeting}</p>
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold">
              <span class="text-gradient-animated">Astakhov Bohdan</span>
            </h1>
          </div>

          <p class="text-xl md:text-2xl font-semibold text-text-muted animate-fade-in-up" style="animation-delay: 0.1s;">
            {t.role}
          </p>

          <p class="text-base md:text-lg text-text-muted leading-relaxed animate-fade-in-up" style="animation-delay: 0.2s;">
            {t.heroDescription}
          </p>

          <div class="grid grid-rows-2 sm:flex w-full   gap-4 justify-center lg:justify-start animate-fade-in-up" style="animation-delay: 0.3s;">
            <a
              href={`/${lang}/#contact`}
              class="inline-flex w-full sm:w-fit items-center gap-2 px-6 py-3 rounded-lg bg-accent text-surface font-semibold
                     hover:bg-accent-hover transition-all duration-300 hover:shadow-lg hover:shadow-accent/30 btn-hover"
            >
              <Icon name="Mail" size={20} client:load />
              {t.contactMe}
            </a>
            <a
              href={`/${lang}/#projects`}
              class="inline-flex w-full sm:w-fit items-center gap-2 px-6 py-3 rounded-lg border border-border
                     text-text-dark font-semibold hover:border-accent hover:text-accent
                     transition-all duration-300"
            >
              <Icon name="Layers" size={20} client:load />
              {t.viewProjects}
            </a>
          </div>

          <!-- Social Links -->
          <div class="flex gap-4 justify-center lg:justify-start pt-4 animate-fade-in-up" style="animation-delay: 0.4s;">
            {socials.map((social, index) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="p-3 rounded-xl border border-border/50 bg-surface/30 backdrop-blur-sm
                       hover:border-accent hover:bg-accent/10 hover:scale-110
                       transition-all duration-300 group"
                aria-label={social.name}
                title={social.name}
                style={`animation-delay: ${0.4 + index * 0.1}s`}
              >
                <Icon name={social.iconName} size={22} class="text-text-muted group-hover:text-accent transition-colors duration-300" client:load />
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="hidden lg:block  absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce-subtle">
        <div class="w-6 h-10 rounded-full border-2 border-border/50 flex items-start justify-center p-2">
          <div class="w-1 h-2 rounded-full bg-accent animate-pulse" />
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-24 px-6">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center space-y-6 reveal">
        <h2 class="text-3xl md:text-5xl font-bold">
          <span class="text-accent">{t.aboutTitle.split(' ')[0]}</span>
          {' '}{t.aboutTitle.split(' ').slice(1).join(' ')}
        </h2>
        <p class="text-lg text-text-muted leading-relaxed max-w-3xl mx-auto">
          {t.aboutDescription}
        </p>
      </div>
    </div>
  </section>

  <!-- Experience Section -->
  <section id="experience" class="py-24 px-6">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-16 reveal">
        <h2 class="text-3xl md:text-5xl font-bold mb-4">
          <span class="text-accent">{t.experienceTitle.split(' ')[0]}</span>
          {' '}{t.experienceTitle.split(' ').slice(1).join(' ')}
        </h2>
        <p class="text-lg text-text-muted">
          {t.experienceDescription}
        </p>
      </div>

      <!-- Timeline -->
      <div class="relative md:pl-8 md:border-l-2 md:border-border space-y-6">
        {localizedExperience.map((exp, index) => (
          <ExperienceCard
            experience={exp}
            index={index}
            client:load
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-24 px-6">
    <div class="container mx-auto max-w-6xl">
      <div class="text-center mb-16 reveal">
        <h2 class="text-3xl md:text-5xl font-bold mb-4">
          <span class="text-accent">{t.projectsTitle.split(' ')[0]}</span>
          {' '}{t.projectsTitle.split(' ').slice(1).join(' ')}
        </h2>
        <p class="text-lg text-text-muted">
          {t.projectsDescription}
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        {localizedProjects.map((project, index) => (
          <ProjectCard
            project={project}
            viewProject={t.viewProject}
            viewCode={t.viewCode}
            index={index}
            client:load
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Skills Section - Full width carousel -->
  <section id="skills" class="py-24">
    <div class="container mx-auto px-6 mb-10">
      <div class="text-center reveal">
        <h2 class="text-3xl md:text-5xl font-bold mb-4">
          <span class="text-accent">{t.skillsTitle.split(' ')[0]}</span>
          {' '}{t.skillsTitle.split(' ').slice(1).join(' ')}
        </h2>
        <p class="text-lg text-text-muted">
          {t.skillsDescription}
        </p>
      </div>
    </div>

    <!-- Full width carousels -->
    <div class="space-y-6">
      {Object.entries(skills).map(([category, skillList], index) => (
        <SkillsCarousel
          skills={skillList}
          category={category}
          speed={20 + index * 5}
          client:load
        />
      ))}
    </div>
  </section>

  <!-- DevOps Pipeline Section -->
  <section class="py-24 px-6">
    <div class="container mx-auto max-w-6xl">
      <div class="text-center mb-16 reveal">
        <h2 class="text-3xl md:text-5xl font-bold mb-4">
          <span class="text-accent">{t.devOpsTitle.split(' ')[0]}</span>
          {' '}{t.devOpsTitle.split(' ').slice(1).join(' ')}
        </h2>
        <p class="text-lg text-text-muted">
          {t.devOpsDescription}
        </p>
      </div>

      <DevOpsPipeline client:load />
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-24 px-6">
    <div class="container mx-auto max-w-2xl text-center reveal">
      <h2 class="text-3xl md:text-5xl font-bold mb-6">
        <span class="text-accent">{t.contactTitle.split(' ')[0]}</span>
        {' '}{t.contactTitle.split(' ').slice(1).join(' ')}
      </h2>
      <p class="text-lg text-text-muted mb-10">
        {t.contactDescription}
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        {socials.map((social, index) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center w-full sm:w-fit gap-3 px-6 py-3 rounded-xl
                   bg-surface/50 backdrop-blur-sm border border-border/50
                   hover:border-accent/50 hover:bg-accent/10
                   transition-all duration-300 group animate-fade-in-up"
            style={`animation-delay: ${index * 0.1}s`}
          >
            <Icon name={social.iconName} size={20} class="text-accent" client:load />
            <span class="font-medium text-text-dark group-hover:text-accent transition-colors duration-300">{social.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  // Intersection Observer for reveal animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
