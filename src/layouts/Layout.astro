---
import type { Locale } from '../constants/data';
import { dictionary } from '../constants/data';
import BaseHead from '../components/BaseHead.astro';
import ThemeToggle from '../components/ThemeToggle';
import LanguagePicker from '../components/LanguagePicker';
import Icon from '../components/Icon';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Locale;
}

const { title, description, lang } = Astro.props;
const t = dictionary[lang];
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} lang={lang} />
  </head>
  <body>
    <!-- Global rain animation -->
    <div class="rain-container">
      <div class="rain-line"></div>
      <div class="rain-line"></div>
      <div class="rain-line"></div>
      <div class="rain-line"></div>
      <div class="rain-line"></div>
      <div class="rain-line"></div>
      <div class="rain-line"></div>
      <div class="rain-line"></div>
      <div class="rain-line"></div>
      <div class="rain-line"></div>
      <div class="rain-line"></div>
      <div class="rain-line"></div>
    </div>

    <!-- Header / Navigation -->
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-bg-dark/80 border-b border-border/30">
      <nav class="container mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
          <!-- Logo -->
          <a href={`/${lang}/`} class="flex items-center gap-2 group">
            <div class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors duration-300">
              <Icon name="Code2" size={18} class="text-accent" client:load />
            </div>
            <span class="text-lg font-bold text-text-dark group-hover:text-accent transition-colors duration-300">
              pippsza.dev
            </span>
          </a>

          <!-- Navigation Links -->
          <div class="hidden md:flex items-center gap-1">
            <a href={`/${lang}/#about`} class="px-4 py-2 rounded-lg text-text-muted hover:text-accent hover:bg-surface/50 transition-all duration-300 text-sm font-medium">
              {t.about}
            </a>
            <a href={`/${lang}/#experience`} class="px-4 py-2 rounded-lg text-text-muted hover:text-accent hover:bg-surface/50 transition-all duration-300 text-sm font-medium">
              {t.experience}
            </a>
            <a href={`/${lang}/#projects`} class="px-4 py-2 rounded-lg text-text-muted hover:text-accent hover:bg-surface/50 transition-all duration-300 text-sm font-medium">
              {t.projects}
            </a>
            <a href={`/${lang}/#skills`} class="px-4 py-2 rounded-lg text-text-muted hover:text-accent hover:bg-surface/50 transition-all duration-300 text-sm font-medium">
              {t.skills}
            </a>
            <a href={`/${lang}/#contact`} class="px-4 py-2 rounded-lg text-text-muted hover:text-accent hover:bg-surface/50 transition-all duration-300 text-sm font-medium">
              {t.contact}
            </a>
          </div>

          <!-- Actions -->
          <div class="flex items-center gap-2">
            <LanguagePicker client:load currentLang={lang} currentPath={Astro.url.pathname} />
            <ThemeToggle client:load />
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="pt-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border/30 mt-24 py-12">
      <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="text-center md:text-left">
            <div class="flex items-center gap-2 justify-center md:justify-start mb-2">
              <div class="w-6 h-6 rounded-md bg-accent/10 flex items-center justify-center">
                <Icon name="Code2" size={14} class="text-accent" client:load />
              </div>
              <span class="font-semibold text-text-dark">pippsza</span>
            </div>
            <p class="text-sm text-text-muted">
              © {new Date().getFullYear()} {t.rights}
            </p>
          </div>

          <div class="text-center md:text-right">
            <p class="text-sm text-text-muted">
              {t.builtWith}
              <span class="text-accent mx-1">Astro</span>
              <span class="text-text-muted/50">+</span>
              <span class="text-accent mx-1">Preact</span>
              <span class="text-text-muted/50">+</span>
              <span class="text-accent mx-1">Tailwind CSS</span>
            </p>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
